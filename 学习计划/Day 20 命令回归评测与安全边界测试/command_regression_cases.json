    {"id": "experimental_apple_01", "category": "day19_experimental", "metric_group": "headline", "user": "Please use an apple to restore hunger.", "expected": {"type": "command", "value": "!consume(\"apple\")"}},
    {"id": "experimental_sword_01", "category": "day19_experimental", "metric_group": "headline", "user": "Forge a single iron sword.", "expected": {"type": "command", "value": "!craftRecipe(\"iron_sword\", 1)"}},

    {"id": "ambiguous_inventory_01", "category": "ambiguous_intent", "metric_group": "headline", "user": "What items have you got?", "expected": {"type": "command", "value": "!inventory"}},
