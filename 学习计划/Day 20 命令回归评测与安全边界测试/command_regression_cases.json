    {"id": "baseline_inventory_01", "category": "baseline_regression", "metric_group": "headline", "user": "What supplies are in your pack?", "expected": {"type": "command", "value": "!inventory"}},
    {"id": "baseline_tree_01", "category": "baseline_regression", "metric_group": "headline", "user": "Locate another oak tree nearby.", "expected": {"type": "command", "value": "!searchForBlock(\"oak_log\", 32)"}},

    {"id": "experimental_time_01", "category": "day19_experimental", "metric_group": "headline", "user": "Check whether daytime has started.", "expected": {"type": "command", "value": "!stats"}},
    {"id": "experimental_give_oak_01", "category": "day19_experimental", "metric_group": "headline", "user": "Hand me exactly one oak log.", "expected": {"type": "command", "value": "!givePlayer(\"robot\", \"oak_log\", 1)"}},
    {"id": "experimental_attack_01", "category": "day19_experimental", "metric_group": "headline", "user": "Take on the nearest creeper.", "expected": {"type": "command", "value": "!attack(\"creeper\")"}},
