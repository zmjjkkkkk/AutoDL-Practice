    {"id": "baseline_wood_01", "category": "baseline_regression", "metric_group": "headline", "user": "Bring back a little timber.", "expected": {"type": "command", "value": "!collectBlocks(\"oak_log\", 4)"}},
    {"id": "baseline_oak_logs_01", "category": "baseline_regression", "metric_group": "headline", "user": "Chop down four oak logs for me.", "expected": {"type": "command", "value": "!collectBlocks(\"oak_log\", 4)"}},
